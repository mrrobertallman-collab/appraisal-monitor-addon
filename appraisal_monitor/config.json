{
  "name": "Appraisal Monitor",
  "version": "1.0.0",
  "slug": "appraisal_monitor",
  "description": "Monitors Gmail for appraisal requests from RPS, Solidifi, Nationwide and Alpine Credits. Sends alerts to Home Assistant.",
  "url": "https://github.com/mrrobertallman-collab/appraisal-monitor-addon",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "map": ["config:rw"],
  "options": {
    "gmail_account_1": "ontarioresidentialappraisal@gmail.com",
    "app_password_1": "",
    "gmail_account_2": "ontarioappraiser@gmail.com",
    "app_password_2": "",
    "ha_token": "",
    "poll_interval": 60,
    "log_level": "info"
  },
  "schema": {
    "gmail_account_1": "str",
    "app_password_1": "str",
    "gmail_account_2": "str",
    "app_password_2": "str",
    "ha_token": "str",
    "poll_interval": "int(30,300)",
    "log_level": "list(debug|info|warning|error)"
  }
}
